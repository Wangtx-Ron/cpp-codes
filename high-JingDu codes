高进度加法:

void add(int a[], int b[])//高精加 
{
	for(int i = 1; i <= l; i++)
	{
		a[i] += b[i];
		a[i + 1] += a[i] / n;//进位 
		a[i] %= n;
	}
	if(a[l + 1] > 0)//考虑从最高位进位到最高位的下一位 
	{
		l++;//长度++ 
	}
}



